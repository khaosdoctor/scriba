# --- Telegram (long polling — no public URL needed) ---
TELEGRAM_BOT_TOKEN=
ALLOWED_TELEGRAM_USER_ID=         # your numeric Telegram user id; everyone else ignored
PORT=8080                         # health-check endpoint only

# --- Transcription backend ---
# TRANSCRIBER is the boot default; /transcriber local|remote switches at runtime and the
# choice is persisted in the DB (survives restart). Set GROQ_API_KEY too if you want to be
# able to switch to remote without a redeploy.
TRANSCRIBER=local                 # "local" (Parakeet sidecar, default) or "remote" (Groq)
# PARAKEET_URL=                   # optional; defaults to the bundled sidecar
# GROQ_API_KEY=                   # required for TRANSCRIBER=remote and for /transcriber remote

# --- Claude Agent SDK (subscription auth, no API key) ---
# Generate once with:  claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# --- Obsidian Local REST API (VFB instance) ---
OBSIDIAN_API_URL=https://127.0.0.1:27124   # self-signed cert on LAN; TLS verify is skipped
OBSIDIAN_API_KEY=

# --- Vault layout (defaults match the Default vault) ---
DAILY_NOTES_DIR=notes/daily notes
DAILY_NOTE_TEMPLATE=internal/templates/Daily Note
JOURNAL_HEADING=Journal
HABITS_HEADING=Habits             # heading whose checklist the nightly habit review walks
ASSETS_DIR=internal/assets/journal
# Path to the vault. In the container leave unset — it defaults to /vault (the bind-mount
# target). Locally, point it at a real vault dir to test the link index. Compose also reads
# it to pick the host mount source (falls back to ./vault).
# SCRIBA_VAULT_HOST_PATH=/home/you/Documents/Obsidian/Default

# --- Storage ---
DB_PATH=/data/scriba.db

# --- Behaviour ---
TZ=Europe/Stockholm
SUMMARY_TIME=23:30
HABITS_TIME=00:00                 # nightly "did you do yesterday's habits?" prompt (local time)
FLUSH_IDLE_MS=30000
FLUSH_MAX_BATCH=8
FLUSH_MAX_WAIT_MS=120000

# Optional: override the enrichment model (defaults to the SDK/subscription default)
# AGENT_MODEL=claude-opus-4-8

# LOG_LEVEL=trace
