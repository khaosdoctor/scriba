{
  "name": "scriba",
  "version": "1.15.0",
  "private": true,
  "description": "Friction-free Telegram journaling bot that writes enriched jots to an Obsidian vault",
  "type": "module",
  "license": "Elastic-2.0",
  "author": "Lucas Santos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khaosdoctor/scriba.git"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "dev": "node --watch --import tsx src/index.ts",
    "migrate": "knex migrate:latest",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "better-sqlite3": "^11.8.0",
    "grammy": "^1.30.0",
    "groq-sdk": "^0.9.0",
    "knex": "^3.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "undici": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.0.0",
    "lefthook": "^2.1.9",
    "typescript": "^5.7.0"
  }
}
